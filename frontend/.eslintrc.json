{
  "env": {
    "browser": true,
    "es2022": true,
    "jest": true
  },
  "extends": ["react-app", "react-app/jest"],
  "ignorePatterns": ["build/", "node_modules/"],
  "rules": {
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ]
  }
}
